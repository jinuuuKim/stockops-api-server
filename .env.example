# StockOps API Environment Variables
# Copy to .env and fill in real values, or use external secret manager

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=stockops
DB_USER=stockops
DB_PASSWORD=your_password_here

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRATION=86400000

# Server
SERVER_PORT=8080

# AI (optional)
AI_MAX_TOKENS=1024

# Logging
LOG_LEVEL=INFO

# MQTT ingestion (enabled: API subscribes to evaluate thresholds and record alert EVENTS only;
# raw measurements are NOT stored — admin-web reads live values from MQTT directly)
STOCKOPS_MQTT_INGESTION_ENABLED=true

# Actuator / Prometheus exposure (include 'prometheus' to enable /actuator/prometheus)
STOCKOPS_ACTUATOR_EXPOSURE=health,info,prometheus
STOCKOPS_ACTUATOR_HEALTH_SHOW_DETAILS=never
STOCKOPS_ENVIRONMENT=local

# Request log level override
STOCKOPS_REQUEST_LOG_LEVEL=INFO

# Comma-separated admin emails notified when an environment alert opens/escalates (optional).
# Webhook endpoints configured in DB are always notified; leave empty to disable email.
STOCKOPS_ENVIRONMENT_ALERT_EMAIL_RECIPIENTS=
